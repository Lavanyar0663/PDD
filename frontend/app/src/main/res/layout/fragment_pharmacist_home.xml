<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/colorBackground">
    
    <!-- Top Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good Morning,"
                android:textSize="14sp"
                android:textColor="@color/colorTextSecondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pharmacist Alex"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary" />
        </LinearLayout>
        
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_launcher_background"
            android:background="@drawable/bg_circle_avatar" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <!-- Pending Orders Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_rounded_white"
                android:padding="24dp"
                android:layout_marginBottom="24dp"
                android:elevation="0dp">
                
                <ImageView
                    android:id="@+id/ivPendingIcon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_circle_cyan_light"
                    android:src="@android:drawable/ic_menu_add"
                    app:tint="#009688"
                    android:padding="8dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PENDING ORDERS"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_marginStart="12dp"
                    app:layout_constraintBottom_toBottomOf="@+id/ivPendingIcon"
                    app:layout_constraintTop_toTopOf="@+id/ivPendingIcon"
                    app:layout_constraintStart_toEndOf="@+id/ivPendingIcon" />
                    
                <TextView
                    android:id="@+id/tvTotalPending"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorSecondary"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toBottomOf="@+id/ivPendingIcon"
                    app:layout_constraintStart_toStartOf="parent" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="total"
                    android:textSize="14sp"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_marginStart="8dp"
                    app:layout_constraintBottom_toBottomOf="@+id/tvTotalPending"
                    app:layout_constraintStart_toEndOf="@+id/tvTotalPending"
                    android:layout_marginBottom="8dp"/>
                    
                <!-- Priority Badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="!  3 High Priority"
                    android:background="@drawable/bg_badge_light_orange"
                    android:textColor="#D32F2F"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:layout_marginTop="12dp"
                    app:layout_constraintTop_toBottomOf="@+id/tvTotalPending"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Mock Chart Image -->
                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/bg_circle_cyan_light"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Search Bar -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_rounded_white"
                android:padding="16dp"
                android:layout_marginBottom="24dp">
                
                <TextView
                    android:id="@+id/tvLookupHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prescription Lookup"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextPrimary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:background="#F4F8FA"
                    android:padding="8dp"
                    app:layout_constraintTop_toBottomOf="@+id/tvLookupHeader">
                    
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@color/colorOutline"
                        android:layout_gravity="center_vertical"/>
                        
                    <EditText
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Search by patient ID or Name"
                        android:textSize="14sp"
                        android:paddingHorizontal="12dp"
                        android:layout_gravity="center_vertical"/>
                        
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_media_play"
                        android:background="@drawable/bg_badge_teal"
                        app:tint="@color/white" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Latest Prescriptions Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Latest Prescriptions"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextPrimary" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View More"
                    android:textColor="#00B3B3"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_light_blue"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLatestPrescriptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
